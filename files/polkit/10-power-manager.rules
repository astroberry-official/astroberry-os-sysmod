polkit.addRule(function(action, subject) {
  if (action.id.indexOf("org.freedesktop.login1.power-off") == 0 &&
      subject.isInGroup("sudo")) {
    return polkit.Result.YES;
  }
});

polkit.addRule(function(action, subject) {
  if (action.id.indexOf("org.freedesktop.login1.reboot") == 0 &&
      subject.isInGroup("sudo")) {
    return polkit.Result.YES;
  }
});
