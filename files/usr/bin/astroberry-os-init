#!/bin/bash

# This file is provided by astroberry-os-sysmod

set -e

# Verify if running as root
if [ "$(id -u)" -ne 0 ]; then exit 1; fi

cleanup() {
    rm -rf /usr/bin/astroberry-os-init
}
trap cleanup EXIT

# Enable radio
nmcli radio wifi on

# Enable file sharing
if [ -e /home/astroberry ] && [ ! -e /home/astroberry/Shared ]; then
    mkdir -p /home/astroberry/Shared && chown astroberry:astroberry /home/astroberry/Shared
    echo -ne "astroberry\nastroberry\n" | smbpasswd -a -s astroberry
fi

# Trust local CA
caddy trust

# Clean AstroDMx leftovers
if [ -e /install.sh ]; then rm -rf /install.sh; fi # AstroDMx leftover
if [ -e /usr/share/desktop-directories/astrodmx.directory ]; then
    echo "NoDisplay=true" >> /usr/share/desktop-directories/astrodmx.directory # remove astrodmx from top level menu
fi
