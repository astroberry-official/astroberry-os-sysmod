#!/bin/bash

# This file is provided by astroberry-os-sysmod

# Exit if not run as root
[ "$(id -u)" -ne 0 ] && exit 1

cleanup() {
    rm -rf /usr/bin/astroberry-os-init
}
trap cleanup EXIT

# Enable radio
nmcli radio wifi on

# Enable file sharing
if [ -e /home/astroberry ] && [ ! -e /home/astroberry/Shared ]; then
    mkdir -p /home/astroberry/Shared && chown astroberry:astroberry /home/astroberry/Shared
    echo -ne "astroberry\nastroberry\n" | smbpasswd -a -s astroberry
fi

# Trust local CA
caddy trust
